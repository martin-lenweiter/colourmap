# Colourmap Web Application — Environment Variables
# Copy to .env.local and fill in values.

# Required — Database (Postgres / Supabase)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Required — AI Coach
ANTHROPIC_API_KEY=

# Optional — Voice (transcribe/synthesize)
MISTRAL_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional — Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Optional — Navigation (FutureMe link; default: https://futureme.app)
NEXT_PUBLIC_FUTUREME_URL=
